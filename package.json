{
  "name": "musinsa",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.9",
    "dotenv": "^17.4.1",
    "tsconfig-paths": "^4.2.0"
  },
  "scripts": {
    "postinstall": "playwright install chromium",
    "test": "playwright test",
    "test:chrome": "PW_USE_SYSTEM_CHROME=1 playwright test",
    "vercel:login": "npx --yes vercel@latest login",
    "ensure-report": "node -e \"require('fs').accessSync('playwright-reports/index.html');\"",
    "deploy:report": "yarn ensure-report && npx --yes vercel@latest deploy playwright-reports",
    "deploy:report:prod": "yarn ensure-report && npx --yes vercel@latest deploy playwright-reports --prod"
  }
}
